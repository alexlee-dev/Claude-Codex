{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "bun"
    ]
  },
  "include": [
    "src/base/**/*.ts",
    "src/core/**/*.ts",
    "src/labs/**/*.ts",
    "tests/**/*.ts"
  ]
}
